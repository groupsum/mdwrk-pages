{
  "$id": "urn:groupsum:schemaorg:class:RsvpAction",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "$ref": "InformAction.schema.json"
    },
    {
      "properties": {
        "@context": {
          "const": "https://schema.org"
        },
        "@type": {
          "const": "RsvpAction"
        },
        "additionalNumberOfGuests": {
          "$ref": "../properties/additionalNumberOfGuests.schema.json",
          "description": "If responding yes, the number of guests who will attend in addition to the invitee."
        },
        "comment": {
          "$ref": "../properties/comment.schema.json",
          "description": "Comments, typically from users."
        },
        "rsvpResponse": {
          "$ref": "../properties/rsvpResponse.schema.json",
          "description": "The response (yes, no, maybe) to the RSVP."
        }
      },
      "required": [
        "@type"
      ],
      "type": "object",
      "unevaluatedProperties": false,
      "x-schemaorg-cardinality": "open-world"
    }
  ],
  "description": "The act of notifying an event organizer as to whether you expect to attend the event.",
  "title": "RsvpAction"
}
