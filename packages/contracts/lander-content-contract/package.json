{
  "name": "@mdwrk/lander-content-contract",
  "version": "0.1.9",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "sideEffects": false,
  "keywords": [
    "lander",
    "content",
    "contract",
    "portable"
  ],
  "description": "Portable content contract types for product landing sites.",
  "scripts": {
    "build": "node ./scripts/generate-schemaorg-vocabulary.mjs && node ./scripts/generate-structured-data-schemas.mjs && tsc -p tsconfig.json && node ./scripts/copy-schemas.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test:schema-conformance": "npm run build && node --test tests/structured-data-schema-registry-t0.test.mjs tests/structured-data-schema-registry-t1.test.mjs tests/structured-data-schema-registry-t2.test.mjs tests/strict-structured-data-intent-validation-t0.test.mjs tests/strict-structured-data-intent-validation-t1.test.mjs tests/strict-structured-data-intent-validation-t2.test.mjs tests/google-active-type-schema-hardening-t0.test.mjs tests/google-active-type-schema-hardening-t1.test.mjs tests/google-active-type-schema-hardening-t2.test.mjs",
    "test": "npm run build && node --test tests/structured-data-schema-registry-t0.test.mjs tests/structured-data-schema-registry-t1.test.mjs tests/structured-data-schema-registry-t2.test.mjs tests/strict-structured-data-intent-validation-t0.test.mjs tests/strict-structured-data-intent-validation-t1.test.mjs tests/strict-structured-data-intent-validation-t2.test.mjs tests/google-active-type-schema-hardening-t0.test.mjs tests/google-active-type-schema-hardening-t1.test.mjs tests/google-active-type-schema-hardening-t2.test.mjs && node ./tests/run-smoke.mjs",
    "prepack": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./template-data-schemas": {
      "types": "./dist/template-data-schemas.d.ts",
      "import": "./dist/template-data-schemas.js"
    },
    "./structured-data-schemas": {
      "types": "./dist/structured-data-schemas.d.ts",
      "import": "./dist/structured-data-schemas.js"
    },
    "./schemas/learning-path.schema.json": "./schemas/learning-path.schema.json",
    "./schemas/course.schema.json": "./schemas/course.schema.json",
    "./schemas/module.schema.json": "./schemas/module.schema.json",
    "./schemas/quiz.schema.json": "./schemas/quiz.schema.json",
    "./schemas/course-test.schema.json": "./schemas/course-test.schema.json",
    "./schemas/structured-data/*.schema.json": "./schemas/structured-data/*.schema.json",
    "./dist/schemas/learning-path.schema.json": "./dist/schemas/learning-path.schema.json",
    "./dist/schemas/course.schema.json": "./dist/schemas/course.schema.json",
    "./dist/schemas/module.schema.json": "./dist/schemas/module.schema.json",
    "./dist/schemas/quiz.schema.json": "./dist/schemas/quiz.schema.json",
    "./dist/schemas/course-test.schema.json": "./dist/schemas/course-test.schema.json",
    "./dist/schemas/structured-data/*.schema.json": "./dist/schemas/structured-data/*.schema.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com"
}
