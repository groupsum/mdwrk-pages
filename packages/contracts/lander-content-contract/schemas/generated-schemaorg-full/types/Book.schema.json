{
  "$id": "urn:groupsum:schemaorg:class:Book",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "$ref": "CreativeWork.schema.json"
    },
    {
      "properties": {
        "@context": {
          "const": "https://schema.org"
        },
        "@type": {
          "const": "Book"
        },
        "abridged": {
          "$ref": "../properties/abridged.schema.json",
          "description": "Indicates whether the book is an abridged edition."
        },
        "bookEdition": {
          "$ref": "../properties/bookEdition.schema.json",
          "description": "The edition of the book."
        },
        "bookFormat": {
          "$ref": "../properties/bookFormat.schema.json",
          "description": "The format of the book."
        },
        "illustrator": {
          "$ref": "../properties/illustrator.schema.json",
          "description": "The illustrator of the book."
        },
        "isbn": {
          "$ref": "../properties/isbn.schema.json",
          "description": "The ISBN of the book."
        },
        "numberOfPages": {
          "$ref": "../properties/numberOfPages.schema.json",
          "description": "The number of pages in the book."
        }
      },
      "required": [
        "@type"
      ],
      "type": "object",
      "unevaluatedProperties": false,
      "x-schemaorg-cardinality": "open-world"
    }
  ],
  "description": "A book.",
  "title": "Book"
}
