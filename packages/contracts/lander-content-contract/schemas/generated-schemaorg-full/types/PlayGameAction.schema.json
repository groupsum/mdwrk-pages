{
  "$id": "urn:groupsum:schemaorg:class:PlayGameAction",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "$ref": "ConsumeAction.schema.json"
    },
    {
      "properties": {
        "@context": {
          "const": "https://schema.org"
        },
        "@type": {
          "const": "PlayGameAction"
        },
        "gameAvailabilityType": {
          "$ref": "../properties/gameAvailabilityType.schema.json",
          "description": "Indicates the availability type of the game content associated with this action, such as whether it is a full version or a demo."
        }
      },
      "required": [
        "@type"
      ],
      "type": "object",
      "unevaluatedProperties": false,
      "x-schemaorg-cardinality": "open-world"
    }
  ],
  "description": "The act of playing a video game.",
  "title": "PlayGameAction"
}
