{
  "$id": "urn:groupsum:schemaorg:class:TravelAction",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "$ref": "MoveAction.schema.json"
    },
    {
      "properties": {
        "@context": {
          "const": "https://schema.org"
        },
        "@type": {
          "const": "TravelAction"
        },
        "distance": {
          "$ref": "../properties/distance.schema.json",
          "description": "The distance travelled, e.g. exercising or travelling."
        }
      },
      "required": [
        "@type"
      ],
      "type": "object",
      "unevaluatedProperties": false,
      "x-schemaorg-cardinality": "open-world"
    }
  ],
  "description": "The act of traveling from a fromLocation to a destination by a specified mode of transport, optionally with participants.",
  "title": "TravelAction"
}
