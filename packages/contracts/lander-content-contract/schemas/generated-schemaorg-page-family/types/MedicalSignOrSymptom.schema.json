{
  "$id": "urn:groupsum:schemaorg:class:MedicalSignOrSymptom",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "$ref": "MedicalCondition.schema.json"
    },
    {
      "properties": {
        "@context": {
          "const": "https://schema.org"
        },
        "@type": {
          "const": "MedicalSignOrSymptom"
        },
        "possibleTreatment": {
          "$ref": "../properties/possibleTreatment.schema.json",
          "description": "A possible treatment to address this condition, sign or symptom."
        }
      },
      "required": [
        "@type"
      ],
      "type": "object",
      "unevaluatedProperties": false,
      "x-schemaorg-cardinality": "open-world"
    }
  ],
  "description": "Any feature associated or not with a medical condition. In medicine a symptom is generally subjective while a sign is objective.",
  "title": "MedicalSignOrSymptom"
}
