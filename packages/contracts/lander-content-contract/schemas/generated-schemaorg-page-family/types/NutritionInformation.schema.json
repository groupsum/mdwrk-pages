{
  "$id": "urn:groupsum:schemaorg:class:NutritionInformation",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "$ref": "StructuredValue.schema.json"
    },
    {
      "properties": {
        "@context": {
          "const": "https://schema.org"
        },
        "@type": {
          "const": "NutritionInformation"
        },
        "calories": {
          "$ref": "../properties/calories.schema.json",
          "description": "The number of calories."
        },
        "carbohydrateContent": {
          "$ref": "../properties/carbohydrateContent.schema.json",
          "description": "The number of grams of carbohydrates."
        },
        "cholesterolContent": {
          "$ref": "../properties/cholesterolContent.schema.json",
          "description": "The number of milligrams of cholesterol."
        },
        "fatContent": {
          "$ref": "../properties/fatContent.schema.json",
          "description": "The number of grams of fat."
        },
        "fiberContent": {
          "$ref": "../properties/fiberContent.schema.json",
          "description": "The number of grams of fiber."
        },
        "proteinContent": {
          "$ref": "../properties/proteinContent.schema.json",
          "description": "The number of grams of protein."
        },
        "saturatedFatContent": {
          "$ref": "../properties/saturatedFatContent.schema.json",
          "description": "The number of grams of saturated fat."
        },
        "servingSize": {
          "$ref": "../properties/servingSize.schema.json",
          "description": "The serving size, in terms of the number of volume or mass."
        },
        "sodiumContent": {
          "$ref": "../properties/sodiumContent.schema.json",
          "description": "The number of milligrams of sodium."
        },
        "sugarContent": {
          "$ref": "../properties/sugarContent.schema.json",
          "description": "The number of grams of sugar."
        },
        "transFatContent": {
          "$ref": "../properties/transFatContent.schema.json",
          "description": "The number of grams of trans fat."
        },
        "unsaturatedFatContent": {
          "$ref": "../properties/unsaturatedFatContent.schema.json",
          "description": "The number of grams of unsaturated fat."
        }
      },
      "required": [
        "@type"
      ],
      "type": "object",
      "unevaluatedProperties": false,
      "x-schemaorg-cardinality": "open-world"
    }
  ],
  "description": "Nutritional information about the recipe.",
  "title": "NutritionInformation"
}
