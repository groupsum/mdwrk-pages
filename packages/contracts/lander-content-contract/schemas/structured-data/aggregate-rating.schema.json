{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mdwrk.com/structured-data/aggregate-rating.schema.json",
  "title": "Structured Data AggregateRating Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ratingValue"
  ],
  "properties": {
    "ratingValue": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "reviewCount": {
      "type": "number"
    },
    "ratingCount": {
      "type": "number"
    },
    "bestRating": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "worstRating": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    }
  }
}
