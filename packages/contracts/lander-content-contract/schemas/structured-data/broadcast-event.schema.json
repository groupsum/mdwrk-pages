{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "broadcastEvent",
  "title": "Structured Data Broadcast Event",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "startDate": {
      "type": "string"
    },
    "endDate": {
      "type": "string"
    },
    "isLiveBroadcast": {
      "type": "boolean"
    }
  }
}
