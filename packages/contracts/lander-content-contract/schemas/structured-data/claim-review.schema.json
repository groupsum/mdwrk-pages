{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mdwrk.com/structured-data/claim-review.schema.json",
  "title": "Structured Data ClaimReview Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "claimReviewed"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "claimReviewed": {
      "type": "string",
      "minLength": 1
    },
    "itemReviewed": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/thingRef"
        }
      ]
    },
    "author": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/thingRef"
        }
      ]
    },
    "reviewRating": {
      "$ref": "#/$defs/aggregateRatingLike"
    },
    "datePublished": {
      "type": "string"
    }
  },
  "$defs": {
    "thingRef": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "thingRef",
      "title": "Structured Data Thing Reference",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "@id": {
          "type": "string"
        },
        "@type": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      }
    },
    "aggregateRatingLike": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "aggregateRatingLike",
      "title": "AggregateRating-like node",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "@id": {
          "type": "string"
        },
        "@type": {
          "type": "string"
        },
        "ratingValue": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "reviewCount": {
          "type": "number"
        },
        "ratingCount": {
          "type": "number"
        },
        "bestRating": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "worstRating": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        }
      }
    }
  }
}
