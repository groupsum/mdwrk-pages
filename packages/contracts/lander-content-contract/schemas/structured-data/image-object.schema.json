{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mdwrk.com/structured-data/image-object.schema.json",
  "title": "Structured Data ImageObject Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["name"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "url": { "type": "string", "minLength": 1 },
    "contentUrl": { "type": "string" },
    "width": { "type": "number" },
    "height": { "type": "number" },
    "caption": { "type": "string" }
  }
}
