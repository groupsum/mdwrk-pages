{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "learningResource",
  "title": "Structured Data LearningResource",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name"
  ],
  "properties": {
    "@context": {
      "type": "string"
    },
    "@type": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "learningResourceType": {
      "type": "string"
    },
    "educationalLevel": {
      "type": "string"
    },
    "teaches": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    }
  }
}
