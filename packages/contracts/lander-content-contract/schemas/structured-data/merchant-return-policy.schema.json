{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mdwrk.com/structured-data/merchant-return-policy.schema.json",
  "title": "Structured Data MerchantReturnPolicy Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "merchantReturnDays": {
      "type": "number"
    },
    "returnPolicyCategory": {
      "type": "string"
    }
  }
}
