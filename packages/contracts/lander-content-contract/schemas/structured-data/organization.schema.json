{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mdwrk.com/structured-data/organization.schema.json",
  "title": "Structured Data Organization Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "logo": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/image"
        }
      ]
    },
    "image": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/image"
        }
      ]
    },
    "sameAs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "image": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "image",
      "title": "Structured Data Image",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "src": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "caption": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        }
      }
    }
  }
}
