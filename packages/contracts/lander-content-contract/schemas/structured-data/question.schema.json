{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mdwrk.com/structured-data/question.schema.json",
  "title": "Structured Data Question Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "text": {
      "type": "string"
    },
    "acceptedAnswer": {
      "$ref": "#/$defs/answer"
    },
    "suggestedAnswer": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/answer"
      }
    },
    "answerCount": {
      "type": "number"
    },
    "eduQuestionType": {
      "type": "string"
    }
  },
  "$defs": {
    "answer": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "answer",
      "title": "Structured Data Answer",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string"
        },
        "upvoteCount": {
          "type": "number"
        },
        "dateCreated": {
          "type": "string"
        },
        "author": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "$ref": "#/$defs/thingRef"
            }
          ]
        }
      }
    },
    "thingRef": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "thingRef",
      "title": "Structured Data Thing Reference",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "@id": {
          "type": "string"
        },
        "@type": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      }
    }
  }
}
