{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mdwrk.com/structured-data/recipe.schema.json",
  "title": "Structured Data Recipe Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "recipeIngredient",
    "recipeInstructions"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "recipeIngredient": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recipeInstructions": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/howToStep"
          }
        }
      ]
    },
    "author": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/thingRef"
        }
      ]
    },
    "datePublished": {
      "type": "string"
    },
    "prepTime": {
      "type": "string"
    },
    "cookTime": {
      "type": "string"
    },
    "totalTime": {
      "type": "string"
    },
    "image": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/image"
        }
      ]
    }
  },
  "$defs": {
    "howToStep": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "howToStep",
      "title": "HowTo Step",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "text"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string"
        },
        "image": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "$ref": "#/$defs/image"
            }
          ]
        }
      }
    },
    "thingRef": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "thingRef",
      "title": "Structured Data Thing Reference",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "@id": {
          "type": "string"
        },
        "@type": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      }
    },
    "image": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "image",
      "title": "Structured Data Image",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "src": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "caption": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        }
      }
    }
  }
}
