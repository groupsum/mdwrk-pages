{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mdwrk.com/structured-data/video-object.schema.json",
  "title": "Structured Data VideoObject Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "thumbnailUrl",
    "uploadDate"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "thumbnailUrl": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "uploadDate": {
      "type": "string",
      "minLength": 1
    },
    "duration": {
      "type": "string"
    },
    "embedUrl": {
      "type": "string"
    },
    "contentUrl": {
      "type": "string"
    },
    "clip": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/clip"
      }
    },
    "publication": {
      "anyOf": [
        {
          "$ref": "#/$defs/broadcastEvent"
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/broadcastEvent"
          }
        }
      ]
    }
  },
  "$defs": {
    "clip": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "clip",
      "title": "Structured Data Clip",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "startOffset": {
          "type": "number"
        },
        "endOffset": {
          "type": "number"
        }
      }
    },
    "broadcastEvent": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "broadcastEvent",
      "title": "Structured Data Broadcast Event",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "startDate": {
          "type": "string"
        },
        "endDate": {
          "type": "string"
        },
        "isLiveBroadcast": {
          "type": "boolean"
        }
      }
    }
  }
}
