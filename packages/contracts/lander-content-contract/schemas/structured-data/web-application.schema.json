{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mdwrk.com/structured-data/web-application.schema.json",
  "title": "Structured Data WebApplication Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "applicationCategory": {
      "type": "string"
    },
    "operatingSystem": {
      "type": "string"
    },
    "offers": {
      "$ref": "#/$defs/offerLike"
    },
    "softwareVersion": {
      "type": "string"
    },
    "image": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/image"
        }
      ]
    }
  },
  "$defs": {
    "offerLike": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "offerLike",
      "title": "Offer-like node",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "@id": {
          "type": "string"
        },
        "@type": {
          "type": "string"
        },
        "price": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "priceCurrency": {
          "type": "string"
        },
        "availability": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "seller": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "$ref": "#/$defs/thingRef"
            }
          ]
        }
      }
    },
    "image": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "image",
      "title": "Structured Data Image",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "src": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "caption": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        }
      }
    }
  }
}
