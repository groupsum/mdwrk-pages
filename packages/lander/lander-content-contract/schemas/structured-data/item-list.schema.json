{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mdwrk.com/structured-data/item-list.schema.json",
  "title": "Structured Data ItemList Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "items"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/itemListEntry" }
    }
  },
  "$defs": {
    "itemListEntry": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "itemListEntry",
      "title": "ItemList Entry",
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string" },
        "item": {}
      }
    }
  }
}
