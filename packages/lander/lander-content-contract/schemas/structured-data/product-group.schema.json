{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mdwrk.com/structured-data/product-group.schema.json",
  "title": "Structured Data ProductGroup Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["name"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "url": { "type": "string", "minLength": 1 },
    "brand": {},
    "sku": { "type": "string" },
    "category": { "type": "string" },
    "offers": {},
    "aggregateRating": {},
    "review": {},
    "hasVariant": {},
    "variesBy": {},
    "image": {}
  }
}
