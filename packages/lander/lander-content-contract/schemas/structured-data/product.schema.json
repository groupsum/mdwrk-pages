{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mdwrk.com/structured-data/product.schema.json",
  "title": "Structured Data Product Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["name"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "url": { "type": "string", "minLength": 1 },
    "brand": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "$ref": "#/$defs/thingRef" }
      ]
    },
    "sku": { "type": "string" },
    "category": { "type": "string" },
    "offers": { "$ref": "#/$defs/offerLike" },
    "aggregateRating": { "$ref": "#/$defs/aggregateRatingLike" },
    "review": {
      "anyOf": [
        { "$ref": "#/$defs/reviewLike" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewLike" }
        }
      ]
    },
    "image": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "$ref": "#/$defs/image" }
      ]
    }
  },
  "$defs": {
    "thingRef": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "thingRef",
      "title": "Structured Data Thing Reference",
      "type": "object",
      "additionalProperties": true,
      "properties": {}
    },
    "offerLike": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "offerLike",
      "title": "Offer-like node",
      "type": "object",
      "additionalProperties": true,
      "properties": {}
    },
    "aggregateRatingLike": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "aggregateRatingLike",
      "title": "AggregateRating-like node",
      "type": "object",
      "additionalProperties": true,
      "properties": {}
    },
    "reviewLike": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "reviewLike",
      "title": "Review-like node",
      "type": "object",
      "additionalProperties": true,
      "properties": {}
    },
    "image": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "image",
      "title": "Structured Data Image",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "src": { "type": "string" },
        "url": { "type": "string" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "caption": { "type": "string" },
        "alt": { "type": "string" }
      }
    }
  }
}
