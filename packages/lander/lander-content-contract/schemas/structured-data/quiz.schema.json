{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mdwrk.com/structured-data/quiz.schema.json",
  "title": "Structured Data Quiz Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "hasPart"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "url": { "type": "string", "minLength": 1 },
    "educationalLevel": { "type": "string" },
    "assesses": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      ]
    },
    "learningResourceType": { "type": "string" },
    "hasPart": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/question" }
    }
  },
  "$defs": {
    "thingRef": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "thingRef",
      "title": "Structured Data Thing Reference",
      "type": "object",
      "additionalProperties": true,
      "properties": {}
    },
    "answer": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "answer",
      "title": "Structured Data Answer",
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string", "minLength": 1 },
        "url": { "type": "string" },
        "upvoteCount": { "type": "number" },
        "dateCreated": { "type": "string" },
        "author": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "$ref": "#/$defs/thingRef" }
          ]
        }
      }
    },
    "question": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "question",
      "title": "Structured Data Question",
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "url": { "type": "string", "minLength": 1 },
        "text": { "type": "string" },
        "acceptedAnswer": { "$ref": "#/$defs/answer" },
        "suggestedAnswer": {
          "type": "array",
          "items": { "$ref": "#/$defs/answer" }
        },
        "answerCount": { "type": "number" },
        "eduQuestionType": { "type": "string" }
      }
    }
  }
}
