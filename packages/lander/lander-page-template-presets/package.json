{
  "name": "@mdwrk/lander-page-template-presets",
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "keywords": [
    "lander",
    "page-template-presets",
    "content",
    "portable"
  ],
  "description": "Ready-made page-template graph presets for MdWrk lander sites.",
  "dependencies": {
    "@mdwrk/lander-content-contract": "^0.1.2",
    "@mdwrk/lander-page-templates": "^0.1.0"
  },
  "scripts": {
    "build": "npm run build -w @mdwrk/lander-page-templates && tsc -p tsconfig.json",
    "typecheck": "npm run build -w @mdwrk/lander-page-templates && tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "npm run build && node ./tests/run-smoke.mjs",
    "prepack": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "import": "./dist/presets/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com"
}
