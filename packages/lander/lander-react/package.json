{
  "name": "@mdwrk/lander-react",
  "version": "0.1.2",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "keywords": [
    "lander",
    "react",
    "components"
  ],
  "description": "Reusable React components for portable product landing sites.",
  "dependencies": {
    "@mdwrk/lander-content-contract": "^0.1.2",
    "@mdwrk/lander-core": "^0.1.2",
    "@mdwrk/structured-data": "^0.1.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3"
  },
  "scripts": {
    "build": "npm run build -w @mdwrk/structured-data && npm run build -w @mdwrk/lander-core && tsc -p tsconfig.json",
    "typecheck": "npm run build -w @mdwrk/structured-data && npm run build -w @mdwrk/lander-core && tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "npm run build && node tests/run-smoke.mjs",
    "prepack": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com"
}
