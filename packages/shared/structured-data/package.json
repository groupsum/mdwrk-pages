{
  "name": "@mdwrk/structured-data",
  "version": "0.1.4",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "keywords": [
    "structured-data",
    "schema.org",
    "json-ld",
    "seo",
    "aeo",
    "aieo"
  ],
  "description": "Reusable Schema.org and JSON-LD builders for MdWrk apps, packages, public content, and discovery surfaces.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "npm run build && node tests/run-smoke.mjs",
    "prepack": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com"
}
