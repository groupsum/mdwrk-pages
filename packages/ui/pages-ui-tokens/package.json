{
  "name": "@mdwrk/pages-ui-tokens",
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "files": [
    "dist",
    "src/styles",
    "README.md"
  ],
  "sideEffects": [
    "./src/styles/root.css",
    "./src/styles/semantic-article.css",
    "./src/styles/semantic-product.css",
    "./src/styles/semantic-course.css",
    "./src/styles/semantic-quiz.css"
  ],
  "keywords": [
    "mdwrk",
    "pages",
    "ui",
    "tokens",
    "css"
  ],
  "description": "Repo-local CSS token package for MdWrk Pages UI surfaces.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "npm run build && node tests/run-smoke.mjs",
    "prepack": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    },
    "./styles/root.css": "./src/styles/root.css",
    "./styles/semantic-article.css": "./src/styles/semantic-article.css",
    "./styles/semantic-product.css": "./src/styles/semantic-product.css",
    "./styles/semantic-course.css": "./src/styles/semantic-course.css",
    "./styles/semantic-quiz.css": "./src/styles/semantic-quiz.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com"
}
